# El Escudo Web v2 — Variables de entorno
# Copia este archivo a .env.local y completa los valores reales.
# .env.local NUNCA se sube al repositorio (.gitignore lo excluye).

# ── Supabase Auth ─────────────────────────────────────────────
# URL del proyecto Supabase (ej: https://xxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Anon key pública de Supabase (NO la service_role key)
# Se obtiene en: Supabase Dashboard > Settings > API > anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-publico

# ── Backend El Escudo ─────────────────────────────────────────
# URL base del backend FastAPI existente
# Default local: http://localhost:8000/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
