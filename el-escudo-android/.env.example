# El Escudo Android — Variables de entorno
# Copia este archivo a .env y completa los valores reales.
# .env NUNCA se sube al repositorio (.gitignore lo excluye).

# URL de la web app oficial (escudo-web-v2 desplegada en Vercel/Producción).
# Debe ser HTTPS y el dominio de producción. NO uses localhost.
EXPO_PUBLIC_WEB_APP_URL=https://tu-dominio.vercel.app

# EAS Project ID (fallback temporal). Si Constants.easConfig esta disponible, este valor se ignora.
EXPO_PUBLIC_EAS_PROJECT_ID=