{
  "expo": {
    "name": "El Escudo",
    "slug": "el-escudo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "android": {
      "package": "com.elescudo.navir",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": true,
      "permissions": [
        "RECORD_AUDIO",
        "RECEIVE_BOOT_COMPLETED",
        "POST_NOTIFICATIONS"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.elescudo.navir",
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "OMNI necesita acceso al micrófono para reconocer comandos de voz.",
        "NSSpeechRecognitionUsageDescription": "OMNI necesita reconocimiento de voz para procesar comandos hablados.",
        "UIBackgroundModes": [
          "fetch",
          "remote-notification"
        ]
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-background-task",
      "expo-notifications"
    ]
  }
}
